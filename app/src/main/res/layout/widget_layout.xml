<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@android:color/holo_blue_dark" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#DD121315"
        android:padding="8dp">

        <!-- Album Art / App Icon representation in Widget -->
        <ImageView
            android:id="@+id/widget_album_art"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_media_play"
            android:background="#33FFFFFF"
            android:padding="8dp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/track_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acoustic Resonance"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/track_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vortex Ambient"
                android:textColor="#A0B2C6"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/track_format"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FLAC | 24-bit / 192 kHz"
                android:textColor="#14DFD0"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#2214DFD0"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Playback Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:padding="4dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="Previous" />

            <ImageView
                android:id="@+id/btn_play"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_media_pause"
                android:padding="4dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="Play/Pause" />

            <ImageView
                android:id="@+id/btn_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_next"
                android:padding="4dp"
                android:contentDescription="Next" />
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
